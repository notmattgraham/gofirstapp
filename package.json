{
  "name": "gofirst",
  "version": "0.2.0",
  "private": true,
  "description": "GoFirst — mobile productivity app (tasks, recurring habits, streaks).",
  "main": "server/index.js",
  "scripts": {
    "dev": "NODE_ENV=development node server/index.js",
    "start": "prisma db push --skip-generate && node server/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
