generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  googleId    String       @unique
  email       String       @unique
  name        String?
  picture     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tasks       Task[]
  quitStreaks QuitStreak[]
}

model Task {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text            String
  // Local-time datetime string (YYYY-MM-DDTHH:MM), used for "Since {date}" display.
  startedAt       String
  // Null = one-shot task. Else { type: 'daily' | 'weekly' | 'custom', daysOfWeek: number[] }.
  recurrence      Json?
  // Only meaningful when recurrence.type === 'daily'. If true, shows on Streaks tab.
  trackStreak     Boolean  @default(false)
  // One of: Family, Fitness, Career, Self-Improvement, Other. Drives analytics breakdown.
  category        String?
  // Developer-mode tasks exist outside the normal rules (no lock enforcement,
  // excluded from execution-rate analytics). Only the designated dev account
  // ever sets this to true. Regular users always submit devMode=false.
  devMode         Boolean  @default(false)
  // For one-shot tasks only (recurrence === null).
  done            Boolean  @default(false)
  // For recurring tasks: local-date strings (YYYY-MM-DD) the task was completed on.
  completedDates  String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model QuitStreak {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  // Local-time datetime string (YYYY-MM-DDTHH:MM).
  startAt   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Managed by connect-pg-simple. Declared here so `prisma db push` doesn't try
// to drop it on every deploy (it's auto-created the first time a session is
// written, but the migration would lose all active logins without this).
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}
