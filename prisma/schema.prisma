generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  googleId    String       @unique
  email       String       @unique
  name        String?
  picture     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // IANA timezone (e.g. "America/New_York"). Sent by the client on each load.
  // Drives midnight calculations and lock enforcement server-side.
  timezone    String?

  // Time-of-day at which "today" rolls over for this user — i.e. when
  // their list locks and a fresh day begins. Stored as "HH:MM" in their
  // local timezone. Default 00:00 (midnight) matches the original
  // behaviour. Lets night-shift workers set e.g. "18:00" so their
  // commitment day runs from 6 PM to 6 PM. Set during onboarding;
  // changeable from Profile (rate-limited via lockTimeChangedAt).
  lockTime    String   @default("00:00")
  // When the user last changed (or first set) their lockTime. Drives
  // the 14-day cooldown — PATCH /api/auth/me rejects further changes
  // while now() < lockTimeChangedAt + 14 days. Initialised at the
  // commit step of onboarding so the cooldown clock starts there.
  lockTimeChangedAt DateTime?

  // Override (a.k.a. mulligan) bookkeeping. 3 free per rolling month.
  overridesUsed       Int      @default(0)
  // First day of the current month-long quota window. Reset every 30 days.
  overrideMonthStart  DateTime @default(now())
  // YYYY-MM-DD string. When this matches the user's local "today", the lock
  // is bypassed for today only (allows add/edit/delete on today's list).
  overrideActiveDate  String?

  // Marks a user as one of the admin's coaching clients. Coaching clients
  // surface in the hidden /admin dashboard with their full task list and
  // analytics so the coach can see how their work is going. Toggled only
  // by the admin account; has no effect on the user's own experience.
  coachingClient      Boolean  @default(false)

  // Marks a user as the coach. The coach sees the iMessage-style inbox of
  // every coaching client in the chat tab and can reply to them. Toggled
  // by the admin via /dev. Falls back to env COACH_EMAIL match in code so
  // the original coach account works before anyone is flagged in the DB.
  isCoach             Boolean  @default(false)

  // Marks a user as the app-wide admin. Admin can broadcast a DM to every
  // user, manage roles, and delete users from /dev. Only one admin exists at
  // a time (the role PATCH demotes any other admin when promoting). Falls
  // back to env ADMIN_EMAIL match in code so the original admin account
  // works before anyone is flagged in the DB.
  isAdmin             Boolean  @default(false)

  // True once the user has finished or skipped the first-login welcome
  // tour. Used to gate auto-display of the tutorial carousel on subsequent
  // sessions. Users can re-trigger the tour from Profile regardless.
  tutorialSeen        Boolean  @default(false)

  // Timestamp of the moment the user finished the commitment-onboarding
  // ritual (listing bad habits to quit + their first three tasks). Null
  // means "still needs onboarding". Users with existing tasks/streaks at
  // the time of the migration get auto-backfilled with their createdAt
  // so they're never asked to onboard retroactively.
  onboardedAt         DateTime?

  // Per-event push toggles. All default true so a freshly-subscribed user
  // gets every kind of notification until they specifically opt out from
  // Profile → Notifications. The toggles bucket events into three groups:
  //   notifyMessages — inbound DM (friend, coach<->client, broadcast reply).
  //   notifyFriends  — friend request received OR your request accepted.
  //   notifySystem   — admin in-app broadcasts and any future system push.
  notifyMessages      Boolean  @default(true)
  notifyFriends       Boolean  @default(true)
  notifySystem        Boolean  @default(true)

  // Updated by the trackLastSeen middleware on authenticated requests
  // (throttled to 1 write/min/user). Drives the "Active now / 5m ago"
  // presence display in the chat header.
  lastSeenAt          DateTime?

  tasks          Task[]
  quitStreaks    QuitStreak[]
  sentMessages   Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  sentFriendships     Friendship[] @relation("SentFriendships")
  receivedFriendships Friendship[] @relation("ReceivedFriendships")
  pushSubscriptions   PushSubscription[]
  dayCommits          DayCommit[]
  nudgeLogs           NudgeLog[]
}

// Per-(user, kind, date) record of a deadline-nudge push having fired,
// so the scheduled job (server/nudges.js) doesn't double-send when its
// 5-minute tick falls inside the same firing window twice.
//   kind: '2h' | '1h' — distance from lockTime when this nudge fires
//   date: YYYY-MM-DD of the day the nudge is for (in user's TZ)
model NudgeLog {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind    String
  date    String
  sentAt  DateTime @default(now())

  @@unique([userId, kind, date])
  @@index([userId])
}

// One row per (user, date) the user has explicitly committed. The
// presence of a row means "the list for this date is locked — no
// adds, no edits, no deletes." Past dates without a row are treated
// as implicitly committed (the day passed, the plan is what it was).
// Today + future require an explicit row to count as committed.
model DayCommit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // YYYY-MM-DD in the user's timezone. Same shape as Task.scheduledDate.
  date        String
  committedAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// Web-push subscription. One row per device the user has enabled
// notifications on (so phone + laptop = 2 rows). Endpoint is the unique
// per-browser push URL; p256dh + auth are the encryption keys we encode
// each push payload against. Rows are removed when web-push reports a
// 404/410 ("subscription gone") on a send attempt.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String   @unique
  p256dh    String
  auth      String

  // What kind of device label the client sent (e.g. user-agent shortform).
  // Diagnostic only — handy when the user has multiple subs and wants to
  // know which is which.
  label     String?

  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([userId])
}

// In-app social graph. A row exists from the requester (fromUserId) to the
// target (toUserId). status starts at 'pending' and flips to 'accepted'
// when the recipient confirms. Either side can delete to unfriend / decline.
model Friendship {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  fromUser   User     @relation("SentFriendships", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User     @relation("ReceivedFriendships", fields: [toUserId], references: [id], onDelete: Cascade)
  status     String   // 'pending' | 'accepted'
  createdAt  DateTime  @default(now())
  acceptedAt DateTime?

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

model Message {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  fromUser   User      @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User      @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)
  content    String
  // Optional inline image attachment. Stored as a base64 data URL
  // ("data:image/jpeg;base64,..."). Client downscales to ~1280px / JPEG
  // before posting, so each row stays under a few hundred KB.
  attachment String?
  // Null = unread. Set to the time the recipient first opened the message.
  readAt     DateTime?
  // Hides this row from the admin's inbox listing only. Set when:
  //   (a) the message was sent as part of an admin broadcast — so a thread
  //       only surfaces in the admin inbox once a reply (which has this
  //       field null) is created, and
  //   (b) the admin "deletes" a conversation — every row in the pair gets
  //       this stamped, and the thread vanishes from the admin's list until
  //       a new reply lands.
  // Does not affect the recipient's view, and does not hide messages once
  // the admin actually opens the thread.
  hiddenFromAdminAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([fromUserId])
  @@index([toUserId])
}

model Task {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text            String
  // Local-time datetime string (YYYY-MM-DDTHH:MM), used for "Since {date}" display.
  startedAt       String
  // Day this task is committed to (YYYY-MM-DD in user TZ). Null for recurring
  // task templates — those are scheduled by recurrence rule, not a fixed date.
  scheduledDate   String?
  // If this task is a re-add of a missed task, points back to the original.
  // The duplicate counts on its own scheduledDate; the original still counts
  // as a miss on its scheduled day.
  parentTaskId    String?
  // Null = one-shot task. Else { type: 'daily' | 'weekly' | 'custom', daysOfWeek: number[] }.
  recurrence      Json?
  // Only meaningful when recurrence.type === 'daily'. If true, shows on Streaks tab.
  trackStreak     Boolean  @default(false)
  // One of: Family, Fitness, Career, Self-Improvement, Other. Drives analytics breakdown.
  category        String?
  // Preferred time of day (24-hour "HH:MM"). Used for Chronological view grouping.
  scheduledTime   String?
  // Optional free-text notes the user attaches to a task — context, links,
  // reminders, anything they need to remember. Up to 1000 chars per the
  // form; stored as String? to allow null when empty.
  notes           String?
  // DEPRECATED — left in schema so `prisma db push` doesn't have to drop the
  // column on deploy (which requires --accept-data-loss). Never read or
  // written by application code; safe to remove in a future migration window.
  devMode         Boolean  @default(false)
  // For one-shot tasks only (recurrence === null).
  done            Boolean  @default(false)
  // For recurring tasks: local-date strings (YYYY-MM-DD) the task was completed on.
  completedDates  String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model QuitStreak {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  // Local-time datetime string (YYYY-MM-DDTHH:MM).
  startAt   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Managed by connect-pg-simple. Declared here so `prisma db push` doesn't try
// to drop it on every deploy (it's auto-created the first time a session is
// written, but the migration would lose all active logins without this).
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}
