generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  // googleId stays @unique but is now nullable. Users who first sign
  // up via Sign in with Apple don't have a Google id, and existing
  // Google users don't have an Apple one. The email field is the
  // join key between the two providers — same email logs in regardless
  // of which provider authenticates them.
  googleId    String?      @unique
  // Apple Sign in subject (sub claim on the id_token). Unique per
  // (app, user) — Apple gives a stable identifier scoped to your
  // Services ID. Required by App Store guideline 4.8 once we ship
  // the iOS native app.
  appleId     String?      @unique
  email       String       @unique
  name        String?
  picture     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // IANA timezone (e.g. "America/New_York"). Sent by the client on each load.
  // Drives what date the server calls "today" for this user.
  timezone    String?

  // Free-form "where I live" string the user enters in Profile. Up to 80 chars.
  location    String?

  // Marks a user as the app-wide admin. Falls back to env ADMIN_EMAIL
  // match in code so the original admin account works before anyone is
  // flagged in the DB.
  isAdmin             Boolean  @default(false)

  // Premium is a STACKABLE attribute. Admins are effective-premium
  // regardless of this flag; see server helpers.
  isPremium           Boolean  @default(false)

  // True once the user has finished or skipped the first-login welcome
  // tour. Users can re-trigger the tour from Profile regardless.
  tutorialSeen        Boolean  @default(false)

  // Timestamp of the moment the user finished the commitment-onboarding
  // ritual. Null means "still needs onboarding".
  onboardedAt         DateTime?

  tasks          Task[]
  quitStreaks    QuitStreak[]
}

model Task {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  text            String
  // Local-time datetime string (YYYY-MM-DDTHH:MM), used for "Since {date}" display.
  startedAt       String
  // Day this task is committed to (YYYY-MM-DD in user TZ). Null for recurring
  // task templates — those are scheduled by recurrence rule, not a fixed date.
  scheduledDate   String?
  // If this task is a re-add of a missed task, points back to the original.
  // The duplicate counts on its own scheduledDate; the original still counts
  // as a miss on its scheduled day.
  parentTaskId    String?
  // Null = one-shot task. Else { type: 'daily' | 'weekly' | 'custom', daysOfWeek: number[] }.
  recurrence      Json?
  // Only meaningful when recurrence.type === 'daily'. If true, shows on Streaks tab.
  trackStreak     Boolean  @default(false)
  // One of: Family, Fitness, Career, Self-Improvement, Other. Drives analytics breakdown.
  category        String?
  // Preferred time of day (24-hour "HH:MM"). Used for Chronological view grouping.
  scheduledTime   String?
  // Optional free-text notes the user attaches to a task. Up to 1000 chars.
  notes           String?
  // DEPRECATED — left in schema so `prisma db push` doesn't have to drop the
  // column on deploy. Safe to remove in a future migration window.
  devMode         Boolean  @default(false)
  // For one-shot tasks only (recurrence === null).
  done            Boolean  @default(false)
  // For recurring tasks: local-date strings (YYYY-MM-DD) the task was completed on.
  completedDates  String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model QuitStreak {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  // Local-time datetime string (YYYY-MM-DDTHH:MM).
  startAt   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Managed by connect-pg-simple. Declared here so `prisma db push` doesn't try
// to drop it on every deploy.
model Session {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}
